      "itemIdentifier": "dde.bbr.metadata.DDEproperties.ddeGeographicDataset",
      "$schema": "metaschema.yaml",
      "name": "DDE Geographic Dataset Properties",
      "abstract": "Conditional extension for geographic dataset resources. Implements MD_SpatialRepresentation (DDE spec Table 5): mandatory spatialCoverage, plus spatialRepresentationType, spatialResolution, referenceSystemType, and referenceSystemIdentifier. Defines properties: schema:spatialCoverage, schema:additionalProperty. Uses building blocks: spatialExtent (schemaorgProperties), additionalProperty (schemaorgProperties), identifier (schemaorgProperties).",
      "status": "under-development",
      "dateTimeAddition": "2026-03-01T00:00:00Z",
      "itemClass": "schema",
      "register": "cdif-building-block-register",
      "version": "0.1",
