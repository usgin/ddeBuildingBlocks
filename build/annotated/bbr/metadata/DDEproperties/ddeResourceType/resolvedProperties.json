{"defs":{},"properties":[{"path":["schema:additionalType"],"id":"http://schema.org/additionalType","description":"Must include at least one DefinedTerm from the DDE ResourceTypeCode codelist.","schema_type":"array","sources":["bblocks://dde.bbr.metadata.DDEproperties.ddeResourceType"],"effectiveId":"http://schema.org/additionalType"},{"path":["schema:additionalType","schema:inDefinedTermSet"],"id":"http://schema.org/inDefinedTermSet","description":"Name for the controlled vocabulary responsible for this keyword.","required":true,"schema_type":"string","const":"dde:codelist/ResourceTypeCode","sources":["bblocks://dde.bbr.metadata.DDEproperties.ddeResourceType","bblocks://cdif.bbr.metadata.schemaorgProperties.definedTerm"],"effectiveId":"http://schema.org/inDefinedTermSet"},{"path":["schema:additionalType","schema:termCode"],"id":"http://schema.org/termCode","description":"A representative code for this keyword in the controlled vocabulary. Analogous to skos:Notation","required":true,"schema_type":"string","enum":["aggregate","application","webApplication","collection","dataset","dataCatalog","geographicDataset","nonGeographicDataset","document","article","thesis","book","poster","webPage","image","map","photograph","explanatoryFigure","initiative","fieldSession","learningResource","guide","model","movie","repository","semanticResource","definedTermSet","series","service","webAPI","software","sound"],"sources":["bblocks://dde.bbr.metadata.DDEproperties.ddeResourceType","bblocks://cdif.bbr.metadata.schemaorgProperties.definedTerm"],"effectiveId":"http://schema.org/termCode"},{"path":["schema:additionalType","schema:identifier"],"sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.definedTerm"]},{"path":["schema:additionalType","schema:identifier","schema:propertyID"],"description":"In this context for the schema:PropertyValue, this field is an identifier for the identifier schema, e.g. DOI, ARK.  Get values from https://registry.identifiers.org/registry/ for interoperability","schema_type":"string","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.identifier"]},{"path":["schema:additionalType","schema:identifier","schema:value"],"description":"the identifier string. E.g. 10.5066/F7VX0DMQ","schema_type":"string","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.identifier"]},{"path":["schema:additionalType","schema:identifier","schema:url"],"description":"web-resolveable string for the identifier; host name part is location of a resolver that will return some representation for the given identifier value. E.g. https://doi.org/10.5066/F7VX0DMQ ","schema_type":"string","format":"uri","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.identifier"]},{"path":["schema:additionalType","schema:name"],"description":"text label for the term that is useful to human user","schema_type":"string","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.definedTerm"]}]}