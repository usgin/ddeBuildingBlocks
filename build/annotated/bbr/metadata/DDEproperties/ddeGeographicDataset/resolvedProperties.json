{"defs":{},"properties":[{"path":["schema:spatialCoverage"],"description":"Spatial extent of the geographic dataset. Mandatory for geographicDataset resource type.","required":true,"schema_type":"array","sources":["bblocks://dde.bbr.metadata.DDEproperties.ddeGeographicDataset"]},{"path":["schema:spatialCoverage","schema:name"],"description":"multiple place names or DefinedTerms that have a place name and URI for the location","schema_type":"array"},{"path":["schema:spatialCoverage","schema:geo"],"description":"Either a bounding box or a point location."},{"path":["schema:spatialCoverage","schema:geo","_anyOf"],"keyword":"anyOf"},{"path":["schema:spatialCoverage","schema:geo","_anyOf","0"],"title":"a","keyword":"branch"},{"path":["schema:spatialCoverage","schema:geo","_anyOf","0","schema:latitude"],"required":true,"schema_type":"number"},{"path":["schema:spatialCoverage","schema:geo","_anyOf","0","schema:longitude"],"required":true,"schema_type":"number"},{"path":["schema:spatialCoverage","schema:geo","_anyOf","1"],"title":"b","keyword":"branch"},{"path":["schema:spatialCoverage","schema:geo","_anyOf","1","schema:box"],"description":"A GeoShape box defines an area on the surface of the earth defined by point locations of the southwest corner and northeast corner of the rectangle in latitude-longitude coordinates. A space should be used to separate the latitude and longitude values. The two corner coordinate points are separated by a space. 'East longitude' means positive longitude values are east of the prime (Greenwich) meridian.","required":true,"schema_type":"string"},{"path":["schema:spatialCoverage","schema:geo","_anyOf","2"],"title":"c","keyword":"branch"},{"path":["schema:spatialCoverage","schema:geo","_anyOf","2","schema:line"],"description":"A GeoShape box defines a curvilinear geometry as a string of latitude-longitude coordinates. A space should be used to separate the latitude and longitude values. The coordinate point pairs are also separated by a space. 'East longitude' means positive longitude values are east of the prime (Greenwich) meridian. e.g. '39.33 120.77 40.44 123.96 41.00 121.34' ","required":true,"schema_type":"string"},{"path":["schema:spatialCoverage","geosparql:hasGeometry"],"description":"Optional geographic extent using wkt geometry, see Ocean InfoHub (https://book.oceaninfohub.org/thematics/spatial/README.html#simple-geosparql-wkt). Other geometry schemes might be specified in a specific domain profile, e.g. for atmospheric, subsurface data, or local coordinate systems. NOTE that the location specified here should be the same as the schema.org point or contained within the specified bounding box.","schema_type":"object"},{"path":["schema:spatialCoverage","geosparql:hasGeometry","geosparql:asWKT"],"schema_type":"object"},{"path":["schema:spatialCoverage","geosparql:hasGeometry","geosparql:crs"],"schema_type":"object"},{"path":["schema:additionalProperty"],"description":"Spatial representation properties using DDE propertyIDs. Each item is a PropertyValue with a DDE propertyID and a value whose type depends on the property.","schema_type":"array","sources":["bblocks://dde.bbr.metadata.DDEproperties.ddeGeographicDataset"]},{"path":["schema:additionalProperty","_anyOf"],"sources":["bblocks://dde.bbr.metadata.DDEproperties.ddeGeographicDataset"],"keyword":"anyOf"},{"path":["schema:additionalProperty","_anyOf","0"],"title":"a","sources":["bblocks://dde.bbr.metadata.DDEproperties.ddeGeographicDataset"],"keyword":"branch"},{"path":["schema:additionalProperty","_anyOf","0","schema:value"],"required":true,"schema_type":"string","enum":["vector","grid","textTable","tin","stereoModel","video"],"sources":["bblocks://dde.bbr.metadata.DDEproperties.ddeGeographicDataset"]},{"path":["schema:additionalProperty","_anyOf","1"],"title":"b","sources":["bblocks://dde.bbr.metadata.DDEproperties.ddeGeographicDataset"],"keyword":"branch"},{"path":["schema:additionalProperty","_anyOf","1","schema:value"],"required":true,"schema_type":"string","sources":["bblocks://dde.bbr.metadata.DDEproperties.ddeGeographicDataset"]},{"path":["schema:additionalProperty","_anyOf","2"],"title":"c","sources":["bblocks://dde.bbr.metadata.DDEproperties.ddeGeographicDataset"],"keyword":"branch"},{"path":["schema:additionalProperty","_anyOf","2","schema:value"],"required":true,"schema_type":"string","enum":["compoundEngineeringParametric","compoundEngineeringParametricTemporal","compoundEngineeringTemporal","compoundEngineeringVertical","compoundEngineeringVerticalTemporal","compoundGeographic2DParametric","compoundGeographic2DParametricTemporal","compoundGeographic2DTemporal","compoundGeographic2DVertical","compoundGeographicVerticalTemporal","compoundGeographic3DTemporal","compoundProjected2DParametric","compoundProjected2DParametricTemporal","compoundProjectedTemporal","compoundProjectedVertical","compoundProjectedVerticalTemporal","engineering","engineeringDesign","engineeringImage","geodeticGeocentric","geodeticGeographic2D","geodeticGeographic3D","geographicIdentifier","linear","parametric","projected","temporal","vertical"],"sources":["bblocks://dde.bbr.metadata.DDEproperties.ddeGeographicDataset"]},{"path":["schema:additionalProperty","_anyOf","3"],"title":"d","sources":["bblocks://dde.bbr.metadata.DDEproperties.ddeGeographicDataset"],"keyword":"branch"},{"path":["schema:additionalProperty","_anyOf","3","schema:value"],"description":"The reference system identifier code (e.g. \"EPSG:4326\", \"urn:ogc:def:crs:EPSG::4326\").","schema_type":"string","sources":["bblocks://dde.bbr.metadata.DDEproperties.ddeGeographicDataset"]},{"path":["schema:additionalProperty","_anyOf","3","schema:url"],"description":"Resolvable URL for the reference system identifier (e.g. \"https://epsg.io/4326\").","schema_type":"string","format":"uri","sources":["bblocks://dde.bbr.metadata.DDEproperties.ddeGeographicDataset"]},{"path":["schema:additionalProperty","_anyOf","4"],"title":"e","sources":["bblocks://dde.bbr.metadata.DDEproperties.ddeGeographicDataset"],"keyword":"branch"},{"path":["schema:additionalProperty","_anyOf","4","schema:value"],"required":true},{"path":["schema:additionalProperty","_anyOf","4","schema:unitCode"]},{"path":["schema:additionalProperty","_anyOf","4","schema:unitText"],"schema_type":"string"},{"path":["schema:spatialCoverage","schema:name","schema:termCode"],"description":"A representative code for this keyword in the controlled vocabulary (Optional).  Analogous to skos:Notation","schema_type":"string"},{"path":["schema:spatialCoverage","schema:name","schema:inDefinedTermSet"],"description":"Identifier for the controlled vocabulary responsible for this keyword.","schema_type":"string"},{"path":["schema:spatialCoverage","schema:name","schema:identifier"]},{"path":["schema:spatialCoverage","schema:name","schema:identifier","schema:propertyID"],"description":"In this context for the schema:PropertyValue, this field is an identifier for the identifier schema, e.g. DOI, ARK.  Get values from https://registry.identifiers.org/registry/ for interoperability","schema_type":"string"},{"path":["schema:spatialCoverage","schema:name","schema:identifier","schema:value"],"description":"the identifier string. E.g. 10.5066/F7VX0DMQ","schema_type":"string"},{"path":["schema:spatialCoverage","schema:name","schema:identifier","schema:url"],"description":"web-resolveable string for the identifier; host name part is location of a resolver that will return some representation for the given identifier value. E.g. https://doi.org/10.5066/F7VX0DMQ ","schema_type":"string","format":"uri"},{"path":["schema:spatialCoverage","schema:name","schema:name"],"description":"text label for the term that is useful to human user","schema_type":"string"},{"path":["schema:additionalProperty","schema:name"],"required":true,"schema_type":"string","sources":["bblocks://dde.bbr.metadata.DDEproperties.ddeGeographicDataset"]},{"path":["schema:additionalProperty","schema:propertyID"],"description":"identifier or name for the property concept quantified by the values in this variable slot. Multiple values can specify the property at different levels of granularity.","required":true,"schema_type":"array","sources":["bblocks://dde.bbr.metadata.DDEproperties.ddeGeographicDataset"]}]}