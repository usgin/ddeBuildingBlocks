{"defs":{},"properties":[{"path":["schema:additionalType"],"description":"additional type assertions for the catalog record node. dcat:CatalogRecord is required.","required":true,"schema_type":"array","sources":["bblocks://cdif.bbr.metadata.cdifProperties.cdifCatalogRecord"]},{"path":["schema:about"],"required":true,"schema_type":"object","sources":["bblocks://cdif.bbr.metadata.cdifProperties.cdifCatalogRecord"]},{"path":["dcterms:conformsTo"],"description":"uri for specifications that this metadata record conforms to. Minimimally should specify uri for CDIF discovery profile.","required":true,"schema_type":"array","sources":["bblocks://cdif.bbr.metadata.cdifProperties.cdifCatalogRecord","bblocks://dde.bbr.metadata.DDEproperties.ddeCatalogRecord"]},{"path":["schema:maintainer"],"description":"Identification of the agent that maintains the metadata, with contact information. Should include person name and affiliation, or position name and affiliation, or just organization name. e-mail address is preferred contact information.","sources":["bblocks://cdif.bbr.metadata.cdifProperties.cdifCatalogRecord"]},{"path":["schema:sdDatePublished"],"description":"date of most recent update to the metadata content","schema_type":"string","format":"date","sources":["bblocks://cdif.bbr.metadata.cdifProperties.cdifCatalogRecord"]},{"path":["schema:includedInDataCatalog"],"description":"identify the source for the origin the metadata record.","schema_type":"object","sources":["bblocks://cdif.bbr.metadata.cdifProperties.cdifCatalogRecord"]},{"path":["schema:includedInDataCatalog","schema:name"],"schema_type":"string","sources":["bblocks://cdif.bbr.metadata.cdifProperties.cdifCatalogRecord"]},{"path":["schema:includedInDataCatalog","schema:url"],"description":"locator to access a landing page for the collection or catalog","schema_type":"string","format":"uri","sources":["bblocks://cdif.bbr.metadata.cdifProperties.cdifCatalogRecord"]},{"path":["schema:includedInDataCatalog","schema:identifier"],"description":"identifier for the collection or catalog; use identifier_type to provide information on identifier scheme and context for identifier","sources":["bblocks://cdif.bbr.metadata.cdifProperties.cdifCatalogRecord"]},{"path":["schema:maintainer","schema:sameAs"],"description":"other identifiers for the person","schema_type":"array","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.person"]},{"path":["schema:maintainer","schema:contactPoint"],"description":"restrict to email only. Schema.org allows telephone and postal contacts as well","schema_type":"object","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.person"]},{"path":["schema:maintainer","schema:contactPoint","schema:email"],"required":true,"schema_type":"string","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.person"]},{"path":["schema:maintainer","schema:affiliation"],"description":"if affiliation is present, value must be a schema:Organization.","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.person"]},{"path":["schema:maintainer","schema:affiliation","schema:sameAs"],"description":"other identifiers for the organization","schema_type":"array","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.organization"]},{"path":["schema:maintainer","schema:affiliation","schema:identifier"],"description":"identifier for organization","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.organization"]},{"path":["schema:maintainer","schema:affiliation","schema:description"],"schema_type":"string","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.organization"]},{"path":["schema:maintainer","schema:affiliation","schema:alternateName"],"description":"other labels by which the organization might be known","schema_type":"string","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.organization"]},{"path":["schema:maintainer","schema:affiliation","schema:name"],"description":"string label for organization that is meaningful for human users","schema_type":"string","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.organization"]},{"path":["schema:maintainer","schema:affiliation","schema:additionalType"],"schema_type":"array","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.organization"]},{"path":["schema:maintainer","schema:affiliation","schema:additionalType","schema:name"],"description":"text label for the term that is useful to human user","schema_type":"string","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.definedTerm"]},{"path":["schema:maintainer","schema:affiliation","schema:additionalType","schema:identifier"],"sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.definedTerm"]},{"path":["schema:maintainer","schema:affiliation","schema:additionalType","schema:inDefinedTermSet"],"description":"Name for the controlled vocabulary responsible for this keyword.","schema_type":"string","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.definedTerm"]},{"path":["schema:maintainer","schema:affiliation","schema:additionalType","schema:termCode"],"description":"A representative code for this keyword in the controlled vocabulary. Analogous to skos:Notation","schema_type":"string","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.definedTerm"]},{"path":["schema:maintainer","schema:alternateName"],"description":"other labels by which the person might be known","schema_type":"string","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.person"]},{"path":["schema:maintainer","schema:identifier"],"description":"identifier for person, recommend ORCID","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.person"]},{"path":["schema:maintainer","schema:identifier","schema:propertyID"],"description":"In this context for the schema:PropertyValue, this field is an identifier for the identifier schema, e.g. DOI, ARK.  Get values from https://registry.identifiers.org/registry/ for interoperability","schema_type":"string","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.identifier"]},{"path":["schema:maintainer","schema:identifier","schema:value"],"description":"the identifier string. E.g. 10.5066/F7VX0DMQ","schema_type":"string","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.identifier"]},{"path":["schema:maintainer","schema:identifier","schema:url"],"description":"web-resolveable string for the identifier; host name part is location of a resolver that will return some representation for the given identifier value. E.g. https://doi.org/10.5066/F7VX0DMQ ","schema_type":"string","format":"uri","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.identifier"]},{"path":["schema:maintainer","schema:description"],"schema_type":"string","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.person"]},{"path":["schema:maintainer","schema:name"],"description":"string label for person that is meaningful for human users, should format consistently. Recommend 'Family Name, Given name' format.","schema_type":"string","sources":["bblocks://cdif.bbr.metadata.schemaorgProperties.person"]}]}